{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "events.schema.json",
  "title": "Eventi SADAGA",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "date", "time", "location", "description", "status"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "integer", "minimum": 1 },
      "title": { "type": "string", "minLength": 1 },
      "date": { "type": "string", "minLength": 1 },
      "time": { "type": "string", "minLength": 1 },
      "location": { "type": "string", "minLength": 1 },
      "description": { "type": "string", "minLength": 1 },
      "status": { "enum": ["upcoming", "past", "special"] },
      "details": {
        "type": "object",
        "required": ["subtitle", "whatToBring", "refreshment", "contact"],
        "additionalProperties": false,
        "properties": {
          "subtitle": { "type": "string" },
          "whatToBring": { "type": "string" },
          "refreshment": { "type": "string" },
          "contact": { "type": "string" }
        }
      }
    },
    "if": { "properties": { "status": { "const": "special" } } },
    "then": { "required": ["details"] }
  }
}
